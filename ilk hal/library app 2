#include <stdio.h>
#include <string.h>

#define MAX 50
#ifndef KITAP_DOSYA
#define KITAP_DOSYA "veri.txt"
#endif

struct Kitap {
    char isbn[20];
    char isim[50];
    char yazar[50];
    int stok;
};

struct Kitap kitaplar[MAX];
int kitapSayisi=0;

void app2KitaplariOku(){
    FILE *dosya;
    char satir[200];

    kitapSayisi=0;
    dosya=fopen(KITAP_DOSYA,"r");

    if(dosya==NULL){
        return;
    }

    while(fgets(satir,sizeof(satir),dosya)!=NULL && kitapSayisi<MAX){
        if(sscanf(satir,"%49[^-]-%49[^-]-%19[^-]-%d",
            kitaplar[kitapSayisi].isim,
            kitaplar[kitapSayisi].yazar,
            kitaplar[kitapSayisi].isbn,
            &kitaplar[kitapSayisi].stok)==4){
            kitapSayisi++;
        }
    }

    fclose(dosya);
}

void app2KitaplariYaz(){
    FILE *dosya;

    dosya=fopen(KITAP_DOSYA,"w");

    if(dosya==NULL){
        return;
    }

    for(int i=0; i<kitapSayisi; i++){
        fprintf(dosya,"%s-%s-%s-%d\n",
            kitaplar[i].isim,
            kitaplar[i].yazar,
            kitaplar[i].isbn,
            kitaplar[i].stok);
    }

    fclose(dosya);
}

//Kitap ekleme
void kitapEkle(){
    app2KitaplariOku();

    if(kitapSayisi>=MAX){
        printf("Kitap bulunamadi.\n");
        return;
    }

    printf("ISBN giriniz: ");
    scanf("%s", kitaplar[kitapSayisi].isbn);

    printf("Kitap ismi giriniz: ");
    scanf(" %[^\n]", kitaplar[kitapSayisi].isim); //%[^\n] bu kisim bosluklari okumasi icin

    printf("Yazar ismi giriniz: ");
    scanf(" %[^\n]", kitaplar[kitapSayisi].yazar);

    printf("Stok girininiz: ");
    scanf("%d", &kitaplar[kitapSayisi].stok);

    kitapSayisi++;
    app2KitaplariYaz();

    printf("Kitap eklendi. \n");
}

//Kitap Listeleme
 void kitapListele(){
    app2KitaplariOku();

    for(int i=0; i<kitapSayisi; i++){
        printf("\nISNB giriniz: %s\n", kitaplar[i].isbn);
        printf("Kitabin ismini giriniz: %s\n", kitaplar[i].isim);
        printf("Yazar ismi giriniz: %s\n", kitaplar[i].yazar);
        printf("Stok giriniz: %d\n", kitaplar[i].stok);
    }
 }


 //Kitap Guncelleme
 void kitapGuncelle(){
    
    char isbn[20];
    int bulundu=0;

    app2KitaplariOku();

    printf("Guncennecek ISBN: ");
    scanf("%s", isbn);

    for(int i=0; i<kitapSayisi; i++){
        if(strcmp(kitaplar[i].isbn, isbn)==0){

            bulundu=1;

            printf("Yeni kitabin ismini giriniz: ");
            scanf(" %[^\n]",kitaplar[i].isim);

            printf("Yeni yazarin ismini giriniz: ");
            scanf(" %[^\n]", kitaplar[i].yazar),

            printf("Yeni stok giriniz: ");
            scanf("%d",&kitaplar[i].stok);

            printf("Kitap guncellendi.\n");
        }
    }
    if(bulundu){
        app2KitaplariYaz();
    }
    if(!bulundu){
        printf("Kitap bulunamadi.\n");
    }
 }

 //Kitap Silme
 void kitapSil(){

    char isbn[20];
    int bulundu=0;

    app2KitaplariOku();

    printf("Silinecek ISBN'yi giriniz: ");
    scanf("%s", isbn);

    for(int i=0; i<kitapSayisi; i++){
        if(strcmp(kitaplar[i].isbn, isbn)==0){
            bulundu=1;

            for(int j=i; j<kitapSayisi-1; j++){
                kitaplar[j]=kitaplar[j+1];
            }
            kitapSayisi--;
            app2KitaplariYaz();

            printf("Kitap silindi.\n");
            break;
        }
    }
    if(!bulundu){
        printf("Kitap bulunamadi.\n");
    }
 }

 int main(){

    int secim;

    while(1){
        printf("\n1- Kitap Ekle\n");
        printf("2- Kitap Listele\n");
        printf("3- Kitap Guncelle\n");
        printf("4- Kitap Sil\n");
        printf("0- Cikis\n");

        printf("Secim: ");
        scanf("%d", &secim);

        switch(secim){

            case 1:kitapEkle();break;
            case 2:kitapListele();break;
            case 3:kitapGuncelle();break;
            case 4:kitapSil();break;
            case 0:return 0;
            default:
            printf("Hatali Secim!\n");
            }
    }
    return 0;

 }
